# Канал с кнопкой «Подать заявку» (embed + кнопка создаются/обновляются при старте бота)
PANEL_CHANNEL_ID=1244666904392630464
# Канал куда уходит заявка рекрутам (Approve / Reject)
MOD_CHANNEL_ID=1418308922216808580
# Роли рекрутеров (через запятую): у кого есть любая — может Approve/Reject
APPROVER_ROLE_IDS=1244666903880925274,1244666903880925273,1255529408467308565,1244666903880925269,1244666903868215437,1244666903868215431
# Роли, которые получает заявитель при одобрении (все сразу)
TARGET_ROLE_IDS=1244666903838851123,1244666903838851117,1244666903868215428,1244666903838851116,1244666903822205016
# Канал аудита (текстовый) — сюда бот пишет запись после одобрения
AUDIT_CHANNEL_ID=1418308922216808580
# Роль @academy — упоминание в сообщении аудита
ACADEMY_ROLE_ID=1489587316925137009
# Ежедневная сводка: кто сколько одобрил за вчера (по DAILY_STATS_TIMEZONE). Пустой канал = выключено.
DAILY_STATS_CHANNEL_ID=1244666906951290939
# Cron: минута час * * * (время в DAILY_STATS_TIMEZONE), по умолчанию 9:00
DAILY_STATS_CRON=0 0 * * *
DAILY_STATS_TIMEZONE=Europe/Moscow
NICKNAME_PATTERN="[{rank}] {firstName} {lastName}"
LOG_LEVEL=info
# true = дублировать JSON-логи в файл (регламент: аудит для админов)
LOG_TO_FILE=false
LOG_FILE_PATH=logs/chopbot.log
